// ==========================================================
// SCHEMA CENTRAL - Plataforma de gestión de restaurantes
// Locales, usuarios/roles/permisos, inventario, pedidos/clientes,
// RRHH, recetas de cocina y ventas para BI.
// ==========================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------
// LOCALES
// -----------------------------
model Location {
  id        String   @id @default(uuid())
  name      String
  city      String
  country   String
  currency  String   // moneda "nativa" del local, ej. USD o COP
  createdAt DateTime @default(now())

  users        User[]
  suppliers    Supplier[]
  inventory    InventoryItem[]
  purchases    Purchase[]
  orders       Order[]
  recipes      Recipe[]
  shifts       Shift[]
  timeOffs     TimeOff[]
  serviceStats ServiceStat[]
  menuItems    MenuItem[]
}

// -----------------------------
// USUARIOS Y ROLES / PERMISOS (RBAC)
// -----------------------------
enum ModuleName {
  INVENTORY // inventario, compras, proveedores
  CRM       // pedidos y clientes
  HR        // RRHH
  KITCHEN   // recetas y normas
  BI        // dashboard de negocio
  ADMIN     // gestión de usuarios/roles
  ORDERS    // pedidos online + POS en tiempo real
}

enum PermissionAction {
  READ
  WRITE
}

model Role {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?

  users       User[]
  permissions RolePermission[]
}

model RolePermission {
  id       String            @id @default(uuid())
  roleId   String
  module   ModuleName
  action   PermissionAction
  role     Role              @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module, action])
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  active       Boolean  @default(true)
  roleId       String
  role         Role     @relation(fields: [roleId], references: [id])
  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id])
  createdAt    DateTime @default(now())
}

// -----------------------------
// INVENTARIO / COMPRAS / PROVEEDORES
// -----------------------------
model Supplier {
  id         String   @id @default(uuid())
  name       String
  contact    String?
  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  items      InventoryItem[]
  purchases  Purchase[]
}

model InventoryItem {
  id           String   @id @default(uuid())
  name         String
  unit         String
  currentStock Float    @default(0)
  minStock     Float    @default(0)
  price        Float
  currency     String   @default("USD")
  supplierId   String
  supplier     Supplier @relation(fields: [supplierId], references: [id])
  locationId   String
  location     Location @relation(fields: [locationId], references: [id])
  updatedAt    DateTime @updatedAt

  @@index([locationId])
}

model Purchase {
  id         String   @id @default(uuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  itemName   String
  quantity   Float
  unitPrice  Float
  currency   String
  createdAt  DateTime @default(now())
}

// -----------------------------
// PEDIDOS / CLIENTES (CRM + IA de sugerencias)
// -----------------------------
model Customer {
  id          String   @id @default(uuid())
  name        String
  email       String?
  phone       String?
  preferences String?
  createdAt   DateTime @default(now())

  orders Order[]
}

enum OrderStatus {
  RECEIVED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum OrderSource {
  ONLINE
  POS
  COUNTER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  NOT_APPLICABLE
}

model Order {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  items      OrderItem[]
  totalUsd   Float
  totalCop   Float?
  createdAt  DateTime @default(now())

  status        OrderStatus   @default(RECEIVED)
  source        OrderSource   @default(ONLINE)
  fulfillment   String        @default("pickup")
  deliveryAddress String?

  paymentStatus      PaymentStatus @default(PENDING)
  stripeSessionId    String?       @unique
  stripePaymentIntentId String?
  updatedAt          DateTime      @updatedAt

  @@index([locationId, status])
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  dishName  String
  quantity  Int
  unitPrice Float
  menuItemId String?
}

model MenuItem {
  id           String   @id @default(uuid())
  name         String
  nameEn       String?
  description  String?
  category     String
  price        Float
  currency     String   @default("USD")
  imageUrl     String?
  available    Boolean  @default(true)
  locationId   String
  location     Location @relation(fields: [locationId], references: [id])
  updatedAt    DateTime @updatedAt

  @@index([locationId, available])
}

// -----------------------------
// RRHH
// -----------------------------
model Employee {
  id          String   @id @default(uuid())
  name        String
  position    String
  email       String   @unique
  active      Boolean  @default(true)

  timeOffs TimeOff[]
  shifts   Shift[]
}

model TimeOff {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  type       String
  startDate  DateTime
  endDate    DateTime
  approved   Boolean  @default(false)
}

model Shift {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  startTime  DateTime
  endTime    DateTime
}

model ServiceStat {
  id               String   @id @default(uuid())
  locationId       String
  location         Location @relation(fields: [locationId], references: [id])
  date             DateTime
  noShows          Int      @default(0)
  reservations     Int      @default(0)
  tableTurnoverMin Float?
  avgMealTimeMin   Float?
}

// -----------------------------
// COCINA
// -----------------------------
model Recipe {
  id           String   @id @default(uuid())
  nameEs       String
  nameEn       String
  instructionsEs String
  instructionsEn String
  rulesEs      String?
  rulesEn      String?
  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id])
  updatedAt    DateTime @updatedAt
}